<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net10.0;net9.0;net8.0</TargetFrameworks>
    <!--
    net48
    -->
    <RuntimeIdentifiers>win-x64;win-x86</RuntimeIdentifiers>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <Nullable>annotations</Nullable>
    <UseAppHost>true</UseAppHost>
    <IsPackable>false</IsPackable>
    <InterceptorsNamespaces Condition="'$(TargetFramework)'=='net10.0'">$(InterceptorsNamespaces);Microsoft.EntityFrameworkCore.GeneratedInterceptors</InterceptorsNamespaces>
    <DbContextName>Synqra.Tests.TestExtendedSqliteDatabaseContext</DbContextName>
    <EFOptimizeContext>false</EFOptimizeContext>
    <EFPrecompileQueriesStage>none</EFPrecompileQueriesStage>
    <EFScaffoldModelStage>none</EFScaffoldModelStage>
  </PropertyGroup>
  <PropertyGroup Condition="$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net8.0')) or $([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net9.0')) or $([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net10.0'))">
    <IsAotCompatible>true</IsAotCompatible>
    <TrimMode>partial</TrimMode>
    <PublishAot>true</PublishAot>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="..\..\Synqra.Utils\_Polyfill.cs" Link="_Polyfill.cs" />
    <FrameworkReference Condition="'$(TargetFramework)' == 'net8.0' Or '$(TargetFramework)' == 'net9.0' Or '$(TargetFramework)' == 'net10.0'" Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="Migrations\*.cs" />
    <Compile Include="Migrations\*.cs" Condition="'$(TargetFramework)'=='net10.0' and '$(Sqlite)' == 'true'" />
    <Compile Remove="CompiledModels\*.cs" />
    <Compile Include="CompiledModels\*.cs" Condition="'$(TargetFramework)'=='net10.0' and '$(Sqlite)' == 'true'" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Synqra.AppendStorage.Abstractions\Synqra.AppendStorage.Abstractions.csproj" />
    <ProjectReference Include="..\..\Synqra.AppendStorage.BlobStorage\Synqra.AppendStorage.BlobStorage.csproj" />
    <ProjectReference Include="..\..\Synqra.AppendStorage.JsonLines\Synqra.AppendStorage.JsonLines.csproj" />
    <ProjectReference Include="..\..\Synqra.BlobStorage.File\Synqra.BlobStorage.File.csproj" />
    <ProjectReference Include="..\..\Synqra.BlobStorage.Sqlite\Synqra.BlobStorage.Sqlite.csproj" />
    <ProjectReference Include="..\..\Synqra.BinarySerializer\Synqra.BinarySerializer.csproj" />
    <ProjectReference Include="..\..\Synqra.CodeGeneration\Synqra.CodeGeneration.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
    <ProjectReference Include="..\..\Synqra.Model\Synqra.Model.csproj" />
    <ProjectReference Include="..\..\Synqra.Projection.File\Synqra.Projection.File.csproj" />
    <ProjectReference Include="..\..\Synqra.Projection.InMemory\Synqra.Projection.InMemory.csproj" />
    <ProjectReference Include="..\..\Synqra.Projection.Sqlite\Synqra.Projection.Sqlite.csproj" Condition="'$(TargetFramework)'=='net10.0'" />
    <ProjectReference Include="..\..\Synqra.Utils\Synqra.Utils.csproj" />
    <ProjectReference Include="..\..\Synqra\Synqra.csproj" />
    <ProjectReference Include="..\Synqra.Tests.TestHelpers\Synqra.Tests.TestHelpers.csproj" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Condition="'$(TargetFramework)'=='net10.0'">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.EntityFrameworkCore.Tasks">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" />
    <PackageReference Include="MongoDB.Bson" />
    <PackageReference Include="MongoDB.Driver" />
    <PackageReference Include="TUnit" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Binder" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Sqlite\" />
  </ItemGroup>

</Project>
